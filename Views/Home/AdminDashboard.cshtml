@{
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>

    <!-- Link to External CSS -->
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true">
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <span style="margin-right: auto;">Cooperative Financing</span>

        <!-- Navigation Links -->
        <div style="display: flex; gap: 10px; margin-right: 40px;">
            <span>Dashboard</span>

            <!-- Dropdown for Administrative -->
            <div class="dropdown-container" style="position: relative;">
                <span onclick="toggleDropdown()" style="cursor: pointer;">Administrative ▼</span>
                <div id="adminDropdown" style="display: none; position: absolute; background: white;
                    color: black; top: 30px; left: 0; width: 160px; box-shadow: 0px 4px 8px rgba(0,0,0,0.2);
                    border-radius: 5px; padding: 10px;">
                    <a asp-controller="Admin" asp-action="AddMember" style="display: block; padding: 8px;   text-decoration: none; color: black;">➕ Add a Member</a>
                    <a href="#" style="display: block; padding: 8px; text-decoration: none; color: black;">📝 Manage Users</a>
                </div>
            </div>

            <span>Reports</span>
        </div>
    </div>

    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2>Menu</h2>
            <div class="menu">
                <button class="active">🏠 HOME</button>
                <button>👤 MEMBER</button>
                <button>💰 LOANS</button>
                <button>💳 PAYMENTS</button>
                <button>🔑 USER</button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="box">👥 MEMBER</div>
            <div class="box">📈 CONTRIBUTION</div>
            <div class="box">💵 MONEY ON HAND</div>
            <div class="box">💰 PAYMENT RECEIVED</div>
            <div class="box">📊 BALANCE TO COLLECT</div>
            <div class="box">🏦 LEND MONEY</div>
            <div class="box">📜 REPORTS</div>
            <div class="box">📌 ACTIVE LOANS</div>
            <div class="box">✔️ APPROVED LOAN</div>
        </div>
    </div>

    <!-- Link to External JavaScript -->
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>

</body>
</html>
